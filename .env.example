# MiroFish Forecast — Environment Variables
# Copy to .env and fill in values

# Flask
FLASK_ENV=development
FLASK_DEBUG=1

# FRED API (free — https://fred.stlouisfed.org/docs/api/api_key.html)
MIROFISH_FRED_API_KEY=your_fred_api_key_here

# Upstash Redis
MIROFISH_REDIS_URL=https://your-instance.upstash.io
MIROFISH_REDIS_TOKEN=your_upstash_token_here

# IB Market Internals Relay (GCE VM internal IP)
MIROFISH_IB_RELAY_URL=http://10.x.x.x:5001

# OpenAI (not used in Phase 1, but reserve the slot)
MIROFISH_OPENAI_API_KEY=your_openai_key_here

# Cloud Run port
PORT=8080
